<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="ping_pong_world">

    <gravity>0 0 -9.81</gravity>

    <!-- Definizione parametri fisici simulazione-->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <!-- Simulazione in tempo reale-->
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- Plugin per la simulazione fisica (gravità, rimbalzi, dinamica...) -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <!-- Plugin per la gestione della scena, invio alla GUI -->
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>

    <gui fullscreen="0">
      <plugin filename="MinimalScene" name="3D View">
        <gz-gui>
          <title>3D View</title>
          <property type="bool" key="showTitleBar">true</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <!-- Nome della scena con le varie impostazioni -->
        <scene>scene</scene>
        <ambient_light>0.8 0.8 0.8</ambient_light>
        <background_color>0.9 0.9 0.9</background_color>
        <camera_pose>-1.3 0 1.2 0 0.39 0</camera_pose>
        <!-- Quali distanze la camera riesce a vedere -->
        <camera_clip>
          <near>0.01</near>
          <far>1000</far>
        </camera_clip>
      </plugin>

      <!-- Plugin per la gestione della scena -->
      <plugin filename="GzSceneManager" name="Scene Manager">
        <gz-gui>
          <property key="resizable" type="bool">true</property>
          <property key="width" type="double">5</property>
          <property key="height" type="double">5</property>
          <property key="state" type="string">floating</property>
          <property key="showTitleBar" type="bool">false</property>
        </gz-gui>
      </plugin>

      <!-- Plugin per il controllo della simulazione (play, pause, step) -->
      <plugin filename="WorldControl" name="World control">
        <gz-gui>
          <title>World control</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="bool" key="resizable">true</property>
          <property type="double" key="height">72</property>
          <property type="double" key="width">121</property>
          <property type="double" key="z">1</property>
          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="left" target="left"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </gz-gui>
        <play_pause>true</play_pause>
        <step>true</step>
        <start_paused>false</start_paused>
        <!-- Canali interni usati da Gazebo per controllare il mondo e ricevere statistiche -->
        <service>/world/ping_pong_world/control</service>
        <stats_topic>/world/ping_pong_world/stats</stats_topic>
      </plugin>

      <!-- Plugin per visualizzare statistiche della simulazione (tempo, iterazioni...) -->
      <plugin filename="WorldStats" name="World stats">
        <gz-gui>
          <title>World stats</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="bool" key="resizable">true</property>
          <property type="double" key="height">110</property>
          <property type="double" key="width">290</property>
          <property type="double" key="z">1</property>
          <property type="string" key="state">floating</property>
          <anchors target="3D View">
            <line own="right" target="right"/>
            <line own="bottom" target="bottom"/>
          </anchors>
        </gz-gui>
        <sim_time>true</sim_time>
        <real_time>true</real_time>
        <real_time_factor>true</real_time_factor>
        <iterations>true</iterations>
        <topic>/world/ping_pong_world/stats</topic>
      </plugin>
    </gui>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="ping_pong_table">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>1 1 0.1</size>
            </box>
          </geometry>
          <surface>
            <bounce>
              <restitution_coefficient>0.85</restitution_coefficient>
              <threshold>0.0001</threshold>
            </bounce>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>1 1 0.1</size>
            </box>
          </geometry>
          <material>
            <ambient>0 0 1 1</ambient>
            <diffuse>0 0 1 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
        </visual>
        <pose>0 0 0.5 0 0 0</pose>
      </link>
    </model>

    <model name="ping_pong_ball">
      <pose>0 0 2 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.0027</mass>
          <inertia>
            <ixx>4.32e-7</ixx>
            <iyy>4.32e-7</iyy>
            <izz>4.32e-7</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <sphere>
              <radius>0.02</radius>
            </sphere>
          </geometry>
          <surface>
            <bounce>
              <restitution_coefficient>0.9</restitution_coefficient>
              <threshold>0.0001</threshold>
            </bounce>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <sphere>
              <radius>0.02</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>