<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="ping_pong_world">

    <gravity>0 0 -9.81</gravity>

    <physics name="default_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.85 0.85 0.85 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.1 -0.9</direction>
    </light>

    <!-- Ground -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>20 20</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.45 0.45 0.45 1</ambient>
            <diffuse>0.45 0.45 0.45 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Ping pong table -->
    <model name="ping_pong_table">
      <static>true</static>

      <!-- Table top -->
      <link name="table_top">
        <!-- top surface at z = 0.76, thickness = 0.04 -->
        <pose>0 0 0.74 0 0 0</pose>

        <collision name="collision">
          <geometry>
            <box>
              <size>2.74 1.525 0.04</size>
            </box>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>10</kd>
                <max_vel>1.0</max_vel>
                <min_depth>0.0005</min_depth>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.25</mu>
                <mu2>0.25</mu2>
              </ode>
            </friction>
            <bounce>
              <restitution_coefficient>0.82</restitution_coefficient>
              <threshold>0.0001</threshold>
            </bounce>
          </surface>
        </collision>

        <visual name="visual">
          <geometry>
            <box>
              <size>2.74 1.525 0.04</size>
            </box>
          </geometry>
          <material>
            <ambient>0.02 0.18 0.55 1</ambient>
            <diffuse>0.02 0.18 0.55 1</diffuse>
            <specular>0.25 0.25 0.25 1</specular>
          </material>
        </visual>
      </link>

      <!-- Net -->
      <link name="net">
        <pose>0 0 0.83625 0 0 0</pose>

        <collision name="collision">
          <geometry>
            <box>
              <size>0.01 1.525 0.1525</size>
            </box>
          </geometry>
        </collision>

        <visual name="visual">
          <geometry>
            <box>
              <size>0.01 1.525 0.1525</size>
            </box>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.95 1</ambient>
            <diffuse>0.95 0.95 0.95 1</diffuse>
            <specular>0.1 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>

      <!-- Legs -->
      <link name="leg_1">
        <pose>1.15 0.62 0.35 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.06 0.06 0.74</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.06 0.06 0.74</size>
            </box>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="leg_2">
        <pose>1.15 -0.62 0.35 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.06 0.06 0.74</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.06 0.06 0.74</size>
            </box>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="leg_3">
        <pose>-1.15 0.62 0.35 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.06 0.06 0.74</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.06 0.06 0.74</size>
            </box>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="leg_4">
        <pose>-1.15 -0.62 0.35 0 0 0</pose>
        <collision name="collision">
          <geometry>
            <box>
              <size>0.06 0.06 0.74</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.06 0.06 0.74</size>
            </box>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Ball -->
    <model name="ping_pong_ball">
      <pose>1.35 0 1.50 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.0027</mass>
          <inertia>
            <ixx>4.32e-7</ixx>
            <iyy>4.32e-7</iyy>
            <izz>4.32e-7</izz>
          </inertia>
        </inertial>

        <collision name="collision">
          <geometry>
            <sphere>
              <radius>0.02</radius>
            </sphere>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>10</kd>
                <max_vel>1.0</max_vel>
                <min_depth>0.0005</min_depth>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.12</mu>
                <mu2>0.12</mu2>
              </ode>
            </friction>
            <bounce>
              <restitution_coefficient>0.89</restitution_coefficient>
              <threshold>0.0001</threshold>
            </bounce>
          </surface>
        </collision>

        <visual name="visual">
          <geometry>
            <sphere>
              <radius>0.02</radius>
            </sphere>
          </geometry>
          <material>
            <ambient>1 0.45 0.05 1</ambient>
            <diffuse>1 0.45 0.05 1</diffuse>
            <specular>0.25 0.25 0.25 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Robot arm -->
    <model name="ping_pong_arm">
      <!-- Positioned on the right side of the table, facing toward the table -->
      <static>false</static>
      <pose>1.60 0 0 0 0 3.14159265359</pose>

      <plugin
        filename="gz-sim-joint-position-controller-system"
        name="gz::sim::systems::JointPositionController">
        <joint_name>joint0</joint_name>
        <topic>/arm/joint0/cmd_pos</topic>
        <p_gain>8.0</p_gain>
        <i_gain>0.02</i_gain>
        <d_gain>0.25</d_gain>
        <cmd_max>20</cmd_max>
        <cmd_min>-20</cmd_min>
      </plugin>

      <plugin
        filename="gz-sim-joint-position-controller-system"
        name="gz::sim::systems::JointPositionController">
        <joint_name>joint1</joint_name>
        <topic>/arm/joint1/cmd_pos</topic>
        <p_gain>8.0</p_gain>
        <i_gain>0.02</i_gain>
        <d_gain>0.25</d_gain>
        <cmd_max>20</cmd_max>
        <cmd_min>-20</cmd_min>
      </plugin>

      <plugin
        filename="gz-sim-joint-position-controller-system"
        name="gz::sim::systems::JointPositionController">
        <joint_name>joint2</joint_name>
        <topic>/arm/joint2/cmd_pos</topic>
        <p_gain>8.0</p_gain>
        <i_gain>0.02</i_gain>
        <d_gain>0.25</d_gain>
        <cmd_max>20</cmd_max>
        <cmd_min>-20</cmd_min>
      </plugin>

      <plugin
        filename="gz-sim-joint-position-controller-system"
        name="gz::sim::systems::JointPositionController">
        <joint_name>joint3</joint_name>
        <topic>/arm/joint3/cmd_pos</topic>
        <p_gain>8.0</p_gain>
        <i_gain>0.02</i_gain>
        <d_gain>0.25</d_gain>
        <cmd_max>20</cmd_max>
        <cmd_min>-20</cmd_min>
      </plugin>

      <plugin
        filename="gz-sim-joint-state-publisher-system"
        name="gz::sim::systems::JointStatePublisher">
        <topic>/arm/joint_state</topic>
        <joint_name>joint0</joint_name>
        <joint_name>joint1</joint_name>
        <joint_name>joint2</joint_name>
        <joint_name>joint3</joint_name>
      </plugin>

      <!-- Link alla base -->
      <link name="base_link">
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <pose>0 0 0.45 0 0 0</pose>
          <mass>8.0</mass>
          <inertia>
            <ixx>0.5688</ixx>
            <iyy>0.5688</iyy>
            <izz>0.0576</izz>
          </inertia>
        </inertial>

        <collision name="collision">
          <pose>0 0 0.45 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.90</length>
            </cylinder>
          </geometry>
        </collision>

        <visual name="visual">
          <pose>0 0 0.45 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.90</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.10 0.10 0.10 1</ambient>
            <diffuse>0.10 0.10 0.10 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="joint0" type="revolute">
        <parent>world</parent>
        <child>base_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-3.14</lower>
            <upper>3.14</upper>
            <effort>100.0</effort>
            <velocity>2.0</velocity>
          </limit>
          <dynamics>
            <damping>0.2</damping>
            <friction>0.02</friction>
          </dynamics>
        </axis>
      </joint>

      <link name="link1">
        <pose>0 0 0.90 0 0 0</pose>
        <inertial>
          <pose>0.225 0 0 0 0 0</pose>
          <mass>0.6</mass>
          <inertia>
            <ixx>0.00036</ixx>
            <iyy>0.010305</iyy>
            <izz>0.010305</izz>
          </inertia>
        </inertial>

        <collision name="collision">
          <pose>0.225 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.45 0.06 0.06</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.2</mu>
                <mu2>0.2</mu2>
              </ode>
            </friction>
            <bounce>
              <restitution_coefficient>0.85</restitution_coefficient>
              <threshold>0.0001</threshold>
            </bounce>
          </surface>
        </collision>

        <visual name="visual">
          <pose>0.225 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.45 0.06 0.06</size>
            </box>
          </geometry>
          <material>
            <ambient>0.1 0.7 0.2 1</ambient>
            <diffuse>0.1 0.7 0.2 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="joint1" type="revolute">
        <parent>base_link</parent>
        <child>link1</child>
        <pose>0 0 0 0 0 0</pose>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-3.14</lower>
            <upper>3.14</upper>
            <effort>80.0</effort>
            <velocity>3.0</velocity>
          </limit>
          <dynamics>
            <damping>0.2</damping>
            <friction>0.02</friction>
          </dynamics>
        </axis>
      </joint>

      <!-- Elbow upper link -->
      <link name="link2">
        <!-- Link frame at joint2 -->
        <pose>0.45 0 0.90 0 0 0</pose>
        <inertial>
          <pose>0.20 0 0 0 0 0</pose>
          <mass>0.5</mass>
          <inertia>
            <ixx>0.0002083</ixx>
            <iyy>0.0067708</iyy>
            <izz>0.0067708</izz>
          </inertia>
        </inertial>

        <collision name="collision">
          <pose>0.20 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.40 0.05 0.05</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.2</mu>
                <mu2>0.2</mu2>
              </ode>
            </friction>
            <bounce>
              <restitution_coefficient>0.85</restitution_coefficient>
              <threshold>0.0001</threshold>
            </bounce>
          </surface>
        </collision>

        <visual name="visual">
          <pose>0.20 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.40 0.05 0.05</size>
            </box>
          </geometry>
          <material>
            <ambient>0.95 0.80 0.10 1</ambient>
            <diffuse>0.95 0.80 0.10 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="joint2" type="revolute">
        <parent>link1</parent>
        <child>link2</child>
        <pose>0 0 0 0 0 0</pose>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-3.14</lower>
            <upper>3.14</upper>
            <effort>60.0</effort>
            <velocity>3.5</velocity>
          </limit>
          <dynamics>
            <damping>0.15</damping>
            <friction>0.02</friction>
          </dynamics>
        </axis>
      </joint>

      <!-- Wrist link -->
      <link name="link3">
        <!-- Link frame at joint3 -->
        <pose>0.85 0 0.90 0 0 0</pose>
        <inertial>
          <pose>0.09 0 0 0 0 0</pose>
          <mass>0.25</mass>
          <inertia>
            <ixx>0.0000667</ixx>
            <iyy>0.0007083</iyy>
            <izz>0.0007083</izz>
          </inertia>
        </inertial>

        <collision name="collision">
          <pose>0.09 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.18 0.04 0.04</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.2</mu>
                <mu2>0.2</mu2>
              </ode>
            </friction>
            <bounce>
              <restitution_coefficient>0.85</restitution_coefficient>
              <threshold>0.0001</threshold>
            </bounce>
          </surface>
        </collision>

        <visual name="visual">
          <pose>0.09 0 0 0 0 0</pose>
          <geometry>
            <box>
              <size>0.18 0.04 0.04</size>
            </box>
          </geometry>
          <material>
            <ambient>0.15 0.35 0.95 1</ambient>
            <diffuse>0.15 0.35 0.95 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="joint3" type="revolute">
        <parent>link2</parent>
        <child>link3</child>
        <pose>0 0 0 0 0 0</pose>
        <axis>
          <xyz>0 1 0</xyz>
          <limit>
            <lower>-1.6</lower>
            <upper>1.6</upper>
            <effort>40.0</effort>
            <velocity>4.0</velocity>
          </limit>
          <dynamics>
            <damping>0.10</damping>
            <friction>0.01</friction>
          </dynamics>
        </axis>
      </joint>

      <link name="racket_link">
        <pose>1.03 0 0.90 0 1.57079632679 0</pose>

        <inertial>
          <pose>0.01 0 0 0 0 0</pose>
          <mass>0.18</mass>
          <inertia>
            <ixx>0.000294</ixx>
            <iyy>0.000294</iyy>
            <izz>0.000576</izz>
          </inertia>
        </inertial>

        <collision name="collision">
          <pose>0.01 0 0 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.08</radius>
              <length>0.02</length>
            </cylinder>
          </geometry>
          <surface>
            <contact>
              <ode>
                <kp>1e6</kp>
                <kd>10</kd>
                <max_vel>1.0</max_vel>
                <min_depth>0.0005</min_depth>
              </ode>
            </contact>
            <friction>
              <ode>
                <mu>0.9</mu>
                <mu2>0.9</mu2>
              </ode>
            </friction>
            <bounce>
              <restitution_coefficient>0.88</restitution_coefficient>
              <threshold>0.0001</threshold>
            </bounce>
          </surface>
        </collision>

        <visual name="visual">
          <pose>0.01 0 0 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.08</radius>
              <length>0.02</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.85 0.10 0.10 1</ambient>
            <diffuse>0.85 0.10 0.10 1</diffuse>
            <specular>0.15 0.15 0.15 1</specular>
          </material>
        </visual>
      </link>

      <joint name="wrist_to_racket" type="fixed">
        <parent>link3</parent>
        <child>racket_link</child>
        <pose>0 0 0 0 0 0</pose>
      </joint>

    </model>

  </world>
</sdf>